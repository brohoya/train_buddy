# ElevenLabs Conversational AI Agent ID (required for voice coaching)
# Create your agent at https://elevenlabs.io/app/conversational-ai
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=your_agent_id_here

# Anthropic API Key (required for AI workout generation)
# Get your key at https://console.anthropic.com/settings/keys
# NOTE: In production, move this to a server — don't ship API keys in client bundles
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_api_key_here
